{
  "name": "react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "pnpm check-types && pnpm eslint && pnpm prettier:check",
    "lint:fix": "pnpm eslint:fix && pnpm prettier:fix",
    "eslint": "eslint --cache --ext .ts,.tsx .",
    "eslint:fix": "pnpm eslint --fix",
    "eslint:check": "cross-env eslint --cache --ext .ts,.tsx .",
    "prettier:check": "prettier --check \"**/*.ts\" \"**/*.tsx\"",
    "prettier:fix": "prettier --write \"**/*.ts\" \"**/*.tsx\"",
    "check-types": "tsc --noemit",
    "preview": "vite preview",
    "prepare": "node checkHusky.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm eslint:check",
      "pnpm prettier:check"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@generouted/react-router": "^1.20.0",
    "@tanstack/react-query": "^5.100.6",
    "antd": "^6.0.1",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "es_ES": "link:antd/locale/es_ES",
    "format": "^0.2.2",
    "lazy": "link:@generouted/react-router/lazy",
    "lucide-react": "^0.556.0",
    "react": "18",
    "react-dom": "18",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.10.1",
    "react-toastify": "^11.0.5",
    "recoil": "^0.7.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.21",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lodash.debounce": "^4.0.8",
    "pnpm": "^10.28.1",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4"
  }
}